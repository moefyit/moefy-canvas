{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "preserve",
    "newLine": "lf",
    "noEmitOnError": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "ES2018",
    "paths": {
      "@moefy-canvas/theme-sparkler/*": ["./packages/theme-sparkler/src/*"],
      "@moefy-canvas/theme-sparkler": ["./packages/theme-sparkler/src"],
      "@moefy-canvas/theme-popper/*": ["./packages/theme-popper/src/*"],
      "@moefy-canvas/theme-popper": ["./packages/theme-popper/src"],
      "@moefy-canvas/theme-ribbon/*": ["./packages/theme-ribbon/src/*"],
      "@moefy-canvas/theme-ribbon": ["./packages/theme-ribbon/src"],
      "@moefy-canvas/theme-sakura/*": ["./packages/theme-sakura/src/*"],
      "@moefy-canvas/theme-sakura": ["./packages/theme-sakura/src"],
      "@moefy-canvas/theme-meteor/*": ["./packages/theme-meteor/src/*"],
      "@moefy-canvas/theme-meteor": ["./packages/theme-meteor/src"],
      "@moefy-canvas/utils/*": ["./packages/utils/src/*"],
      "@moefy-canvas/utils": ["./packages/utils/src"],
      "@moefy-canvas/core/*": ["./packages/core/src/*"],
      "@moefy-canvas/core": ["./packages/core/src"]
    }
  }
}
